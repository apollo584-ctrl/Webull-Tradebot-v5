{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "v5-evaluation-record",
  "title": "V5 Blind Evaluation Record",
  "type": "object",
  "required": ["protocol_id", "case_id", "cluster_id", "source_message_id", "message_timestamp", "input_hash", "prompt_hash", "model_config_hash", "model_id", "normalized_decision", "latency_ms", "parse_status", "independent_label", "v4_baseline", "contamination_status", "contamination_flags"],
  "properties": {
    "protocol_id": {"type": "string", "minLength": 1},
    "case_id": {"type": "string", "minLength": 1},
    "cluster_id": {"type": "string", "minLength": 1},
    "source_message_id": {"type": "string", "minLength": 1},
    "message_timestamp": {"type": "string", "format": "date-time"},
    "input_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "prompt_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "model_config_hash": {"type": "string", "pattern": "^[A-Fa-f0-9]{64}$"},
    "model_id": {"type": "string", "minLength": 1},
    "provider": {"type": ["string", "null"]},
    "model_output": {"type": ["object", "string", "null"]},
    "normalized_decision": {
      "type": "object",
      "required": ["action", "symbol", "direction", "status"],
      "properties": {
        "action": {"enum": ["OPEN", "ADD", "TRIM", "SELL", "WATCH", "NONE", "REVIEW"]},
        "symbol": {"enum": ["SPY", "QQQ", "IWM", null]},
        "direction": {"enum": ["LONG", "SHORT", null]},
        "status": {"enum": ["actionable", "no_action", "ambiguous", "insufficient_context"]}
      },
      "allOf": [
        {"if": {"properties": {"action": {"enum": ["OPEN", "ADD", "TRIM", "SELL"]}}}, "then": {"properties": {"status": {"const": "actionable"}, "symbol": {"type": "string"}, "direction": {"type": "string"}}}},
        {"if": {"properties": {"action": {"enum": ["WATCH", "NONE"]}}}, "then": {"properties": {"status": {"const": "no_action"}}}},
        {"if": {"properties": {"action": {"const": "REVIEW"}}}, "then": {"properties": {"status": {"enum": ["ambiguous", "insufficient_context"]}}}}
      ],
      "additionalProperties": false
    },
    "latency_ms": {"type": "number", "minimum": 0},
    "parse_status": {"enum": ["ok", "invalid_json", "invalid_decision", "timeout", "error"]},
    "independent_label": {"type": "object"},
    "v4_baseline": {"type": "object"},
    "contamination_status": {"enum": ["clear", "excluded", "unresolved"]},
    "contamination_flags": {
      "type": "array",
      "items": {"enum": ["historical_exact_match", "historical_near_duplicate", "prior_model_review", "manual_correction", "prompt_example", "parser_rule_tuning", "threshold_tuning", "unresolved_provenance"]},
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
